# Copy to .env and adjust values.

# Frontend
FRONTEND_PORT=5173
# Set to your backend base URL.
# - Direct backend dev: http://localhost:3000
# - Through Traefik API router: https://fakaperformance.com/api
VITE_API_BASE_URL=http://localhost:3000

# Backend
BACKEND_PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Discord OAuth placeholders
DISCORD_CLIENT_ID=replace_me
DISCORD_CLIENT_SECRET=replace_me
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# JWT placeholders
JWT_ACCESS_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
AUTH_EXCHANGE_CODE_TTL=60

# Database
POSTGRES_DB=fakap
POSTGRES_USER=fakap
POSTGRES_PASSWORD=fakap
POSTGRES_PORT=5432
DATABASE_URL=postgresql://fakap:fakap@postgres:5432/fakap?schema=public

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# External withdrawal provider
WITHDRAWAL_PROVIDER_URL=http://host.docker.internal:8081/withdraw
WITHDRAWAL_PROVIDER_API_KEY=replace_me_withdrawal_api_key
WITHDRAWAL_PROVIDER_USER_AGENT=tdc-backend
WITHDRAWAL_PROVIDER_TIMEOUT_MS=8000

# External deposit ingestion auth key
DEPOSIT_API_KEY=replace_me_deposit_secret
